{% extends 'base.html.twig' %}

{% block content %}

{% include 'partials/subpage-hero.html.twig' %}

<div class="section">
  <div class="container">

    <header class="section-header" style="margin-block-start: 0;">
      <h2>Wählen Sie Ihre bevorzugte Beratungsform</h2>
    </header>

    <div class="grid-auto-md">
      {% for option in page.header.buchungsoptionen %}
        <article class="card card-feature card-interactive">
          <div class="card-header">
            <h3 class="card-title">{{ option.titel }}</h3>
            <p class="card-description">{{ option.beschreibung }}</p>
          </div>
          <div class="card-footer">
            <a href="{{ option.url }}"
               class="btn btn-primary btn-full"
               {% if option.extern ?? false %}target="_blank" rel="noopener noreferrer"{% endif %}>
              Termin buchen
            </a>
          </div>
        </article>
      {% endfor %}
    </div>

    {# CTA #}
    <section class="mt-12" style="background: var(--color-bg-subtle); border-radius: var(--radius-xl); text-align: center; padding: var(--space-10);" aria-labelledby="termin-cta-title">
      <h3 id="termin-cta-title">Bereit für eine Beratung?</h3>
      <p class="text-muted" style="margin-block: var(--space-3) var(--space-6);">
        Kontaktieren Sie mich für Ihre kostenlose Erstberatung oder vereinbaren Sie einen Termin
      </p>
      <div class="btn-group justify-center">
        <a href="tel:+4923054459886" class="btn btn-primary">Jetzt anrufen</a>
        <a href="/preise" class="btn btn-secondary">Preise ansehen</a>
      </div>
    </section>

  </div>
</div>

{% endblock %}
